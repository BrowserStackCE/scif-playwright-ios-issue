{
  "name": "node-js-playwright-browserstack",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "sample-test": "npx browserstack-node-sdk playwright test --config=./playwright.config.js",
    "sample-percy-test": "npx percy exec -- browserstack-node-sdk playwright test --config=./playwright.config.js",
    "sample-test-ios": "npx playwright test --config=./playwright.config.js --project='safari@iPhone 15:17@browserstack-mobile'",
    "sample-local-test": "npx browserstack-node-sdk playwright test --config=./playwright.local.config.js",
    "postinstall": "npm update browserstack-node-sdk",
    "local-run": "npx playwright test --config=./playwright.config.js --project=Chrome --headed"
  },
