    "browserstack-node-sdk": "1.56.3",
    "cucumber-html-reporter": "^6.0.0",
    "playwright": "^1.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@percy/cli": "^1.31.14",
    "@percy/playwright": "^1.1.0"
  }
